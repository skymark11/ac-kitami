# Claude Code ローカル設定
.claude/settings.local.json

# ローカル専用フォルダ（FTPアップロード不要）
_local/

# 一時ファイル
*.tmp
*.tmp.*
*~
*.swp
.DS_Store
Thumbs.db

# バックアップファイル
*.bak
*.bak.*

# ビルドツール（FTPアップロード不要）
node_modules/
package.json
package-lock.json
tailwind.config.js
css/tailwind-input.css

# 写真分類パイプラインの中間生成物（classification.json + organize.py から再生成可能）
# byカテゴリの振り分けコピーは容量大で確認後は不要
images/works/*/*/_classification/by_category/

# 写真素材の生データ（Dropbox 同期で別途管理、Git 対象外）
assets/photos/_inbox/
