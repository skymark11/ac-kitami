# ===== Xサーバー固有 =====
SetEnvIf Request_URI ".*" Ngx_Cache_NoCacheMode=off
SetEnvIf Request_URI ".*" Ngx_Cache_AllCacheMode

# ===== 基本設定 =====
AddDefaultCharset UTF-8
DirectoryIndex index.html index.htm

# ===== セキュリティ =====
# ディレクトリリスティング無効化
Options -Indexes

# .htaccessファイルへのアクセス拒否
<Files ~ "^\.ht">
    Require all denied
</Files>

# 隠しファイルへのアクセス拒否
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# バックアップ・設定ファイルへのアクセス拒否
<FilesMatch "\.(bak|config|sql|fla|psd|ini|log|sh|inc|swp|dist)$">
    Require all denied
</FilesMatch>

# ===== HTTPS・URL正規化 =====
RewriteEngine On
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\.ac-kitami\.com [NC]
RewriteRule ^(.*)$ https://ac-kitami.com/$1 [L,R=301]

# 旧URL → 新URL 301リダイレクト（インデックス引き継ぎ）
# 2026-06-22: /kitami/works/001/ を /works/001/ に統合
Redirect 301 /kitami/works/001/ https://ac-kitami.com/works/001/

# ===== Gzip圧縮 =====
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/atom+xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/ttf
    AddOutputFilterByType DEFLATE font/otf
    AddOutputFilterByType DEFLATE application/font-woff
    AddOutputFilterByType DEFLATE application/font-woff2
</IfModule>

# ===== ブラウザキャッシュ =====
<IfModule mod_expires.c>
    ExpiresActive On

    # デフォルト
    ExpiresDefault "access plus 1 month"

    # HTML（更新が多いため短め）
    ExpiresByType text/html "access plus 1 day"

    # CSS / JavaScript（1年）
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"

    # 画像（1年）
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # フォント（1年）
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"

    # PDF（1ヶ月）
    ExpiresByType application/pdf "access plus 1 month"
</IfModule>

# ===== Cache-Control ヘッダー =====
<IfModule mod_headers.c>
    # HTML: 短めキャッシュ + 再検証
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "public, max-age=86400, must-revalidate"
    </FilesMatch>

    # CSS / JS / 画像 / フォント: 長期キャッシュ
    <FilesMatch "\.(css|js|jpg|jpeg|png|gif|webp|svg|ico|woff|woff2|ttf|otf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # KeepAlive
    Header set Connection keep-alive
</IfModule>

# ===== ETag無効化 =====
<IfModule mod_headers.c>
    Header unset ETag
</IfModule>
FileETag None
